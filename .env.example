# Network Segment Manager Configuration

# Application Settings
APP_NAME=Network Segment Manager
APP_VERSION=1.0.0
DEBUG=false

# Server Settings
HOST=0.0.0.0
PORT=8000
RELOAD=false

# Database Settings
DATABASE_URL=sqlite:///./data/segment_database.db

# CORS Settings (comma-separated)
ALLOWED_ORIGINS=*
ALLOWED_METHODS=*
ALLOWED_HEADERS=*

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=logs/segment_manager.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Sample Data Settings
LOAD_SAMPLE_DATA=true